# =============================================================================
# .env.example — Copy to .env and adjust as needed
#
# IMPORTANT: This file is safe to commit.  The .env file is git-ignored.
#            Change the default passwords even for local labs on shared machines.
# =============================================================================

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=zabbix_lab_password

# ---- Zabbix server ----------------------------------------------------------
# Database connection (used by zabbix-server container)
ZBX_DB_HOST=postgres
ZBX_DB_PORT=5432
ZBX_DB_NAME=${POSTGRES_DB}
ZBX_DB_USER=${POSTGRES_USER}
ZBX_DB_PASSWORD=${POSTGRES_PASSWORD}

# Zabbix server hostname (must match what the web frontend connects to)
ZBX_SERVER_HOST=zabbix-server

# Comma-separated list of IPs/CIDRs allowed to send trapper data.
# 0.0.0.0/0 allows any host — fine for a local lab.
ZBX_ALLOWED_HOSTS=0.0.0.0/0

# ---- Zabbix web frontend ----------------------------------------------------
# Timezone shown in the UI (see https://www.php.net/manual/en/timezones.php)
PHP_TZ=Europe/Berlin

# ---- Ports exposed on localhost ---------------------------------------------
# Zabbix web UI
ZABBIX_WEB_PORT=8080

# Zabbix trapper port (used by zabbix_sender and Python client)
ZABBIX_TRAPPER_PORT=10051

# ---- Bootstrap / provisioning -----------------------------------------------
# Default Zabbix admin credentials used by bootstrap.py
ZABBIX_API_URL=http://localhost:${ZABBIX_WEB_PORT}/api_jsonrpc.php
ZABBIX_ADMIN_USER=Admin
ZABBIX_ADMIN_PASSWORD=zabbix

# Name of the host that represents the macOS sender
SENDER_HOST_NAME=macos-local-sender
SENDER_HOST_GROUP=MacOS Senders
