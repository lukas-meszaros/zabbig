# =============================================================================
# metrics.yaml.example — Metric definitions for the zabbig client
#
# Copy to metrics.yaml and customise:
#   cp metrics.yaml.example metrics.yaml
#
# Structure:
#   version            — schema version (currently 1)
#   defaults           — global defaults applied to every metric
#   collector_defaults — per-collector overrides of the global defaults
#   metrics            — list of individual metric definitions
# =============================================================================

version: 1

# ---------------------------------------------------------------------------
# Global defaults — applied to every metric unless overridden at a lower level
# ---------------------------------------------------------------------------
defaults:
  enabled: true
  delivery: batch
  timeout_seconds: 10
  error_policy: skip
  importance: normal
  tags: []

# ---------------------------------------------------------------------------
# Collector-level defaults — override global defaults for a specific collector
# ---------------------------------------------------------------------------
collector_defaults:
  cpu:
    timeout_seconds: 5
    delivery: batch
  memory:
    timeout_seconds: 5
    delivery: batch
  disk:
    timeout_seconds: 10
    delivery: batch
  service:
    timeout_seconds: 8
    delivery: immediate     # service state changes are sent immediately

# ---------------------------------------------------------------------------
# Metrics
# ---------------------------------------------------------------------------
metrics:

  # ---- CPU ---------------------------------------------------------------

  - id: cpu_util
    name: CPU utilization percent
    description: Current total CPU utilization as a percentage.
    enabled: true
    collector: cpu
    key: host.cpu.util
    value_type: float
    unit: "%"
    delivery: batch
    importance: normal
    timeout_seconds: 5
    error_policy: skip
    tags: [system, cpu]
    params:
      mode: percent

  - id: load_avg_1
    name: Load average 1-minute
    description: System load average over 1 minute.
    enabled: true
    collector: cpu
    key: host.cpu.load1
    value_type: float
    unit: ""
    delivery: batch
    importance: normal
    timeout_seconds: 5
    error_policy: skip
    tags: [system, cpu]
    params:
      mode: load1

  - id: load_avg_5
    name: Load average 5-minute
    description: System load average over 5 minutes.
    enabled: true
    collector: cpu
    key: host.cpu.load5
    value_type: float
    unit: ""
    delivery: batch
    importance: normal
    timeout_seconds: 5
    error_policy: skip
    tags: [system, cpu]
    params:
      mode: load5

  - id: load_avg_15
    name: Load average 15-minute
    description: System load average over 15 minutes.
    # Disabled — enables: false means this metric is skipped entirely
    enabled: false
    collector: cpu
    key: host.cpu.load15
    value_type: float
    unit: ""
    delivery: batch
    importance: low
    timeout_seconds: 5
    error_policy: skip
    tags: [system, cpu]
    params:
      mode: load15

  - id: uptime
    name: System uptime seconds
    description: How long the system has been running, in seconds.
    enabled: true
    collector: cpu
    key: host.system.uptime
    value_type: float
    unit: "s"
    delivery: batch
    importance: low
    timeout_seconds: 5
    error_policy: skip
    tags: [system]
    params:
      mode: uptime

  # ---- Memory ------------------------------------------------------------

  - id: mem_used_percent
    name: Memory used percent
    description: Percentage of RAM currently in use.
    enabled: true
    collector: memory
    key: host.memory.used_percent
    value_type: float
    unit: "%"
    delivery: batch
    importance: normal
    timeout_seconds: 5
    error_policy: skip
    tags: [system, memory]
    params:
      mode: used_percent

  - id: mem_available_bytes
    name: Memory available bytes
    description: Amount of RAM available for new allocations (MemAvailable).
    enabled: true
    collector: memory
    key: host.memory.available_bytes
    value_type: int
    unit: "B"
    delivery: batch
    importance: normal
    timeout_seconds: 5
    error_policy: skip
    tags: [system, memory]
    params:
      mode: available_bytes

  - id: swap_used_percent
    name: Swap used percent
    description: Percentage of swap space in use. Returns 0 if no swap is configured.
    enabled: true
    collector: memory
    key: host.memory.swap_used_percent
    value_type: float
    unit: "%"
    delivery: batch
    importance: low
    timeout_seconds: 5
    # fallback to 0 if /proc/meminfo is unreadable (should not happen normally)
    error_policy: fallback
    fallback_value: "0"
    tags: [system, memory]
    params:
      mode: swap_used_percent

  # ---- Disk --------------------------------------------------------------

  - id: disk_root_used_percent
    name: Root filesystem used percent
    description: Percentage of / filesystem used.
    enabled: true
    collector: disk
    key: host.disk.root.used_percent
    value_type: float
    unit: "%"
    delivery: batch
    importance: high
    timeout_seconds: 10
    error_policy: skip
    tags: [system, disk]
    params:
      mount: "/"
      mode: used_percent

  - id: disk_root_free_bytes
    name: Root filesystem free bytes
    description: Free bytes on the / filesystem (available to non-root).
    enabled: true
    collector: disk
    key: host.disk.root.free_bytes
    value_type: int
    unit: "B"
    delivery: batch
    importance: high
    timeout_seconds: 10
    error_policy: skip
    tags: [system, disk]
    params:
      mount: "/"
      mode: free_bytes

  - id: disk_data_used_percent
    name: /data filesystem used percent
    description: Percentage of /data filesystem used.
    # Disabled — enable if you have a separate data partition
    enabled: false
    collector: disk
    key: host.disk.data.used_percent
    value_type: float
    unit: "%"
    delivery: batch
    importance: normal
    timeout_seconds: 10
    error_policy: skip
    tags: [system, disk]
    params:
      mount: "/data"
      mode: used_percent

  # ---- Services ----------------------------------------------------------

  - id: svc_sshd
    name: sshd service state
    description: >
      1 = sshd is active (running), 0 = sshd is not active.
      Uses systemd check (systemctl is-active sshd).
    enabled: true
    collector: service
    key: host.service.sshd
    value_type: int
    unit: ""
    delivery: immediate     # service checks are sent immediately when collected
    importance: critical
    timeout_seconds: 8
    error_policy: mark_failed
    tags: [service, ssh]
    params:
      check_mode: systemd
      service_name: sshd

  - id: svc_nginx
    name: nginx service state
    description: 1 = nginx running, 0 = nginx not running.
    # Disable if nginx is not installed on this host
    enabled: true
    collector: service
    key: host.service.nginx
    value_type: int
    unit: ""
    delivery: immediate
    importance: critical
    timeout_seconds: 8
    error_policy: fallback
    fallback_value: "0"       # treat collector error the same as service down
    tags: [service, web]
    params:
      check_mode: systemd
      service_name: nginx

  - id: svc_cron_process
    name: cron process check
    description: >
      Process-pattern fallback for checking if cron is running.
      Uses /proc scan — works without systemd.
    enabled: true
    collector: service
    key: host.service.cron.process
    value_type: int
    unit: ""
    delivery: immediate
    importance: normal
    timeout_seconds: 8
    error_policy: skip
    tags: [service, cron]
    params:
      check_mode: process
      process_pattern: "cron"   # matches 'cron', 'crond', etc.
